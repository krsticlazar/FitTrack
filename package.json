{
  "name": "fittrack",
  "version": "1.0.0",
  "description": "FitTrack - Web aplikacija za praćenje vežbi i napretka u teretani",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "client": "cd app && npm start",
    "server": "nodemon server/index.js",
    "build": "cd app && npm run build",
    "install-all": "npm install && cd app && npm install"
  },
  "keywords": [
    "fitness",
    "workout",
    "mongodb",
    "nodejs",
    "react"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^8.0.3",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "axios": "^1.6.2",
    "express-validator": "^7.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
